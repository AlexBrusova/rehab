# JDBC для Spring. Локально — полный jdbc: URL.
# Railway (надёжно): jdbc:postgresql://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
# Либо postgresql://… от плагина — при старте нормализуется (в т.ч. jdbc:postgresql:user@host → jdbc:postgresql://user@host).
DATABASE_URL=jdbc:postgresql://localhost:5432/rehab
# при необходимости:
# SPRING_DATASOURCE_USERNAME=rehab
# SPRING_DATASOURCE_PASSWORD=secret

JWT_SECRET=your-super-secret-key-change-this-min-32-chars
PORT=4000

# Кеш: по умолчанию Caffeine (application.yml). Для Redis в Docker см. docker-compose / профиль docker.
# SPRING_DATA_REDIS_HOST=localhost
# SPRING_DATA_REDIS_PORT=6379
# SPRING_CACHE_TYPE=redis
