generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model House {
  id    String @id @default(cuid())
  name  String
  city  String
  color String @default("#0d7377")

  users          User[]
  patients       Patient[]
  rooms          Room[]
  groups         Group[]
  shifts         Shift[]
  schedules      Schedule[]
  consequences   Consequence[]
  cashbox        CashboxEntry[]
  cashboxCounts  CashboxCount[]
  dailySummaries DailySummary[]
  absences       Absence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id              String  @id @default(cuid())
  username        String  @unique
  passwordHash    String
  name            String
  role            Role
  roleLabel       String
  initials        String
  color           String  @default("#1e5fa8")
  phone           String?
  allHousesAccess Boolean @default(false)
  houseId         String?

  house             House?                @relation(fields: [houseId], references: [id])
  allowedHouses     UserHouseAccess[]
  shifts            Shift[]
  schedules         Schedule[]
  dailySummaries    DailySummary[]
  therapySessions   TherapySession[]
  therapistPatients TherapistAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  org_manager
  manager
  counselor
  doctor
  therapist
}

model UserHouseAccess {
  userId  String
  houseId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, houseId])
}

model Patient {
  id          String        @id @default(cuid())
  name        String
  dob         String
  admitDate   String
  daysInRehab Int           @default(0)
  mood        Int           @default(5)
  roomId      String?
  houseId     String
  status      PatientStatus @default(active)
  alert       Boolean       @default(false)
  dischargeType String?
  dischargeDate String?

  house             House               @relation(fields: [houseId], references: [id])
  room              Room?               @relation(fields: [roomId], references: [id])
  meds              Med[]
  distributions     MedDistribution[]
  finances          Finance[]
  consequences      Consequence[]
  phones            Phone[]
  absences          Absence[]
  absenceHistory    AbsenceHistory[]
  therapyAssignment TherapistAssignment?
  therapySessions   TherapySession[]
  groupAttendance   GroupAttendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PatientStatus {
  active
  archived
}

model Room {
  id       String @id @default(cuid())
  number   String
  building String
  capacity Int    @default(2)
  houseId  String

  house    House   @relation(fields: [houseId], references: [id])
  patients Patient[]

  createdAt DateTime @default(now())
}

model Med {
  id           String   @id @default(cuid())
  patientId    String
  name         String
  dose         String
  unit         String   @default("mg")
  times        String[]
  startDate    String?
  endDate      String?
  prescribedBy String?
  notes        String?

  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  distributions MedDistribution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MedDistribution {
  id        String  @id @default(cuid())
  patientId String
  medId     String
  date      String
  time      String
  given     Boolean @default(false)
  givenAt   String?
  givenBy   String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  med     Med     @relation(fields: [medId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Finance {
  id        String      @id @default(cuid())
  patientId String
  type      FinanceType
  amount    Int
  source    String
  note      String
  date      String
  balance   Int

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum FinanceType {
  deposit
  withdrawal
}

model CashboxEntry {
  id      String      @id @default(cuid())
  houseId String
  type    FinanceType
  amount  Int
  cat     String
  note    String
  date    String
  time    String
  by      String
  balance Int

  house House @relation(fields: [houseId], references: [id])

  createdAt DateTime @default(now())
}

model CashboxCount {
  id        String  @id @default(cuid())
  houseId   String
  countedBy String
  amount    Int
  expected  Int
  diff      Int
  date      String
  time      String
  notes     String?

  house House @relation(fields: [houseId], references: [id])

  createdAt DateTime @default(now())
}

model Group {
  id       String @id @default(cuid())
  houseId  String
  date     String
  topic    String
  leaderId String?
  notes    String?

  house      House            @relation(fields: [houseId], references: [id])
  attendance GroupAttendance[]

  createdAt DateTime @default(now())
}

model GroupAttendance {
  groupId   String
  patientId String
  present   Boolean @default(false)

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@id([groupId, patientId])
}

model Phone {
  id         String      @id @default(cuid())
  patientId  String
  givenAt    String
  returnBy   String
  returnedAt String?
  late       Boolean     @default(false)
  status     PhoneStatus @default(active)

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum PhoneStatus {
  active
  returned
}

model Shift {
  id           String      @id @default(cuid())
  houseId      String
  counselorId  String
  date         String
  shift        String      @default("24h")
  status       ShiftStatus @default(pending)
  note         String?
  receivedFrom String?
  handedTo     String?
  accepted     Boolean     @default(false)
  start        String?
  end          String?

  house     House @relation(fields: [houseId], references: [id])
  counselor User  @relation(fields: [counselorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ShiftStatus {
  pending
  ACTIVE
  completed
}

model Schedule {
  id          String @id @default(cuid())
  houseId     String
  counselorId String
  date        String
  shiftType   String @default("24h")
  note        String?

  house     House @relation(fields: [houseId], references: [id])
  counselor User  @relation(fields: [counselorId], references: [id])

  createdAt DateTime @default(now())
}

model Consequence {
  id          String            @id @default(cuid())
  patientId   String
  houseId     String
  type        String
  description String
  date        String
  status      ConsequenceStatus @default(pending)
  approvedBy  String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  house   House   @relation(fields: [houseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ConsequenceStatus {
  pending
  approved
  rejected
}

model Absence {
  id          String        @id @default(cuid())
  patientId   String
  houseId     String
  type        String
  startDate   String
  endDate     String
  approvedBy  String?
  status      AbsenceStatus @default(pending)
  returnedAt  String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  house   House   @relation(fields: [houseId], references: [id])

  createdAt DateTime @default(now())
}

enum AbsenceStatus {
  pending
  approved
  active
  returned
}

model AbsenceHistory {
  id        String @id @default(cuid())
  patientId String
  type      String
  start     String
  end       String
  approvedBy String?
  status    String

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model TherapistAssignment {
  patientId   String @id
  therapistId String

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist User    @relation(fields: [therapistId], references: [id])
}

model TherapySession {
  id            String         @id @default(cuid())
  patientId     String
  therapistId   String
  date          String
  topic         String
  notes         String
  urgency       TherapyUrgency @default(NORMAL)
  counselorNote String?

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist User    @relation(fields: [therapistId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TherapyUrgency {
  NORMAL
  URGENT
}

model DailySummary {
  id              String @id @default(cuid())
  counselorId     String
  houseId         String
  date            String
  generalText     String
  patientSummaries Json
  notifiedAt      String?

  counselor User  @relation(fields: [counselorId], references: [id])
  house     House @relation(fields: [houseId], references: [id])

  createdAt DateTime @default(now())
}
